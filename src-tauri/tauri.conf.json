{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "copyright": "",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "../packaging/linux/LyricSeekPro.desktop",
        "files": {
          "/usr/share/metainfo/com.yorkdev.lyricseekpro.metainfo.xml": "../packaging/linux/com.yorkdev.lyricseekpro.metainfo.xml"
        },
        "depends": []
      },
      "appimage": {
        "files": {
          "/usr/share/metainfo/com.yorkdev.lyricseekpro.metainfo.xml": "../packaging/linux/com.yorkdev.lyricseekpro.metainfo.xml"
        },
        "bundleMediaFramework": false
      },
      "rpm": {
        "desktopTemplate": "../packaging/linux/LyricSeekPro.desktop",
        "files": {
          "/usr/share/metainfo/com.yorkdev.lyricseekpro.metainfo.xml": "../packaging/linux/com.yorkdev.lyricseekpro.metainfo.xml"
        },
        "depends": []
      }
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "resources": [],
    "shortDescription": "Desktop lyrics tool with multi-provider support for your offline music library.",
    "targets": "all"
  },
  "productName": "LyricSeek Pro",
  "mainBinaryName": "LyricSeekPro",
  "identifier": "com.yorkdev.lyricseekpro",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768,
        "width": 1024,
        "height": 768,
        "resizable": true,
        "title": "LyricSeek Pro",
        "decorations": true,
        "transparent": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ],
        "enable": true
      },
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob:; media-src *; connect-src ipc: http://ipc.localhost 'self' asset: *; style-src 'unsafe-inline' 'self'"
    }
  }
}
